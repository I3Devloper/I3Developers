---
import { site } from "@/data/site";
import { getGoogleReviews, mergeReviews } from "@/lib/googleReviews";

const liveData = await getGoogleReviews();
const { rating, total, reviews } = mergeReviews(liveData);

const displayRating = rating.toFixed(1);
const reviewLabel = total ? `${total}+ Google Reviews` : "25+ Google Reviews";
---

<section class="testimonials-section">
  <div class="container">
    <div class="testimonials-header">
      <div>
        <p class="eyebrow">Client Success</p>
        <h2>What Lafayette businesses say about i3Developers.</h2>
      </div>
      <div class="google-badge-card">
        <div class="google-logo">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path fill="#EA4335" d="M12 5.04c1.66 0 3.2.57 4.38 1.69l3.27-3.27C17.67 1.6 15.02 1 12 1 7.37 1 3.4 3.66 1.48 7.54l3.89 3c.96-2.88 3.66-5.5 6.63-5.5z"/>
            <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.02 3.68-8.64z"/>
            <path fill="#FBBC05" d="M5.37 14.54c-.24-.72-.37-1.5-.37-2.3a7.8 7.8 0 01.37-2.3L1.48 7.54C.54 9.43 0 11.59 0 13.88s.54 4.45 1.48 6.34l3.89-3z"/>
            <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.92l-3.77-2.92c-1.04.7-2.38 1.12-4.19 1.12-2.97 0-5.67-2.62-6.63-5.5l-3.89 3C3.4 20.34 7.37 23 12 23z"/>
          </svg>
          <span class="badge-title">Google Rating</span>
        </div>
        <div class="badge-rating">
          <strong>{displayRating}</strong>
          <span class="stars">★★★★★</span>
          <small>{reviewLabel}</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Full-width marquee — outside container so it bleeds edge to edge -->
  <div class="marquee-wrap" aria-label="Customer reviews">
    <div class="marquee-track">
      {/* Render twice for seamless infinite loop */}
      {[...reviews, ...reviews].map((t, i) => (
        <article class="review-card" aria-hidden={i >= reviews.length ? "true" : "false"}>
          <div class="review-top">
            <span class="stars-rating" aria-label={`${t.rating ?? 5} stars`}>{"★".repeat(t.rating ?? 5)}</span>
            <span class="source-tag">{t.source}</span>
          </div>
          <blockquote>"{t.quote}"</blockquote>
          <footer>
            <strong>{t.author}</strong>
            <small>{("date" in t && t.date) ? t.date : t.title}</small>
          </footer>
        </article>
      ))}
    </div>
  </div>

  <div class="container">
    <div class="testimonials-cta">
      <p>Happy with our partnership?</p>
      <div class="cta-row">
        <a href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="button google-review-btn">
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path fill="currentColor" d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 12h-2v-2h2v2zm0-4h-2V6h2v4z"/>
          </svg>
          Review us on Google
        </a>
        {site.facebookUrl && (
          <a href={site.facebookUrl} target="_blank" rel="noopener noreferrer" class="button social-btn facebook-btn" aria-label="Follow i3Developers on Facebook">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.5c-1.5 0-1.96.93-1.96 1.89v2.26h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/>
            </svg>
            Facebook
          </a>
        )}
        {site.instagramUrl && (
          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="button social-btn instagram-btn" aria-label="Follow i3Developers on Instagram">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            Instagram
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: clamp(4rem, 8vw, 7.5rem) 0;
    background: linear-gradient(180deg, var(--white) 0%, rgba(220, 238, 242, 0.5) 100%);
  }

  .testimonials-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .testimonials-header h2 { max-width: 620px; margin-top: 0.6rem; }

  .google-badge-card {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1rem 1.4rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(16,33,31,0.04);
    flex-shrink: 0;
  }

  .google-logo { display: flex; flex-direction: column; align-items: center; gap: 0.28rem; }
  .badge-title { font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(16,33,31,0.6); }
  .badge-rating { display: flex; flex-direction: column; align-items: flex-start; gap: 0.1rem; border-left: 1px solid var(--line); padding-left: 1.2rem; }
  .badge-rating strong { font-size: 1.6rem; line-height: 1; color: var(--ink); }
  .badge-rating .stars { color: var(--moss); font-size: 1rem; letter-spacing: 0.05em; }
  .badge-rating small { font-size: 0.72rem; font-weight: 700; color: rgba(16,33,31,0.5); }

  /* ── Infinite marquee ─────────────────────────────────────── */
  .marquee-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin: 0 0 3rem;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }

  .marquee-track {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 1.25rem;
    width: max-content;
    animation: marquee 40s linear infinite;
    will-change: transform;
  }

  .marquee-wrap:hover .marquee-track { animation-play-state: paused; }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .review-card {
    flex: 0 0 340px;
    width: 340px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 24px;
    box-shadow: 0 8px 28px rgba(16,33,31,0.05);
  }

  .review-top { display: flex; justify-content: space-between; align-items: center; }

  .stars-rating { color: #f5c842; font-size: 1rem; letter-spacing: 0.06em; }

  .source-tag {
    font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--cypress); background: rgba(13,115,119,0.08); padding: 0.25rem 0.55rem; border-radius: 99px;
  }

  .review-card blockquote {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.55;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    flex: 1;
    /* clamp to 5 lines so cards stay uniform height */
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .review-card footer {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    border-top: 1px solid var(--line);
    padding-top: 0.9rem;
  }

  .review-card footer strong { font-size: 0.92rem; font-weight: 800; color: var(--ink); }
  .review-card footer small  { font-size: 0.8rem; color: rgba(16,33,31,0.5); font-weight: 700; }

  /* CTA row */
  .testimonials-cta { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; text-align: center; }
  .testimonials-cta p { font-weight: 800; color: rgba(16,33,31,0.68); }

  .cta-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }

  .google-review-btn { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--ink); color: var(--white); box-shadow: 0 12px 28px rgba(16,33,31,0.16); }
  .google-review-btn:hover { background: var(--bayou); }

  .social-btn { display: inline-flex; align-items: center; gap: 0.5rem; }
  .facebook-btn  { background: #1877f2; color: #fff; border-color: #1877f2; }
  .facebook-btn:hover  { background: #166fe5; border-color: #166fe5; }
  .instagram-btn { background: linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); color: #fff; border-color: transparent; }
  .instagram-btn:hover { opacity: 0.9; }

  @media (max-width: 860px) {
    .testimonials-header { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
