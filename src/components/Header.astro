---
import { Image } from "astro:assets";
import logo from "@/assets/i3Developers-mainlogo-white.png";
import { nav, site } from "@/data/site";
import { services } from "@/data/services";
---

<header class="site-header">
  <div class="container nav-wrap">
    <a href="/" class="brand" aria-label="i3Developers home">
      <Image src={logo} alt="i3Developers - Lafayette Web Design, SEO & Digital Marketing Agency" width={375} height={90} format="webp" loading="eager" />
    </a>
    
    <button class="menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>

    <div class="nav-menu">
      <nav aria-label="Primary navigation">
        {nav.map((item) =>
          item.label === "Services" ? (
            <div class="nav-dropdown">
              <a class="nav-link" href={item.href} aria-haspopup="true" aria-expanded="false">
                {item.label}
                <span aria-hidden="true" class="caret">▾</span>
              </a>
              <div class="dropdown-panel" aria-label="Services menu">
                <button class="submenu-back" aria-label="Back to main menu">
                  ← Back
                </button>
                {services.map((service) => (
                  <a href={`/services/${service.slug}/`}>
                    <strong>{service.shortTitle}</strong>
                    <small>{service.eyebrow}</small>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a class="nav-link" href={item.href}>{item.label}</a>
          )
        )}
      </nav>
      <a class="nav-cta" href={site.phoneHref}>{site.phone}</a>
      <a class="nav-cta nav-cta-primary" href="/contact/">Request Estimate</a>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const navMenu   = document.querySelector('.nav-menu') as HTMLElement;
  const body      = document.body;

  function closeMenu() {
    toggleBtn.setAttribute('aria-expanded', 'false');
    navMenu.classList.remove('is-active');
    body.classList.remove('no-scroll');
    // also collapse any open submenu
    document.querySelectorAll('.nav-dropdown.is-open').forEach(d => {
      d.classList.remove('is-open');
      d.querySelector('.nav-link')?.setAttribute('aria-expanded', 'false');
    });
  }

  if (toggleBtn && navMenu) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';
      if (isOpen) { closeMenu(); } else {
        toggleBtn.setAttribute('aria-expanded', 'true');
        navMenu.classList.add('is-active');
        body.classList.add('no-scroll');
      }
    });

    document.addEventListener('click', (e) => {
      if (navMenu.classList.contains('is-active') &&
          !navMenu.contains(e.target as Node) &&
          !toggleBtn.contains(e.target as Node)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  // Services submenu toggle on mobile
  document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
    const link = dropdown.querySelector('.nav-link') as HTMLElement;
    const backBtn = dropdown.querySelector('.submenu-back') as HTMLElement;

    link?.addEventListener('click', (e) => {
      if (window.innerWidth <= 900) {
        e.preventDefault();
        const isOpen = dropdown.classList.contains('is-open');
        // close all first
        document.querySelectorAll('.nav-dropdown.is-open').forEach(d => {
          d.classList.remove('is-open');
          d.querySelector('.nav-link')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          dropdown.classList.add('is-open');
          link.setAttribute('aria-expanded', 'true');
        }
      }
    });

    backBtn?.addEventListener('click', () => {
      dropdown.classList.remove('is-open');
      link?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style is:global>
  body.no-scroll {
    overflow: hidden;
  }
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(13, 115, 119, 0.94);
    backdrop-filter: blur(18px);
  }

  .nav-wrap {
    display: flex;
    min-height: 82px;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    max-width: 136px;
    text-decoration: none;
    transition: opacity 180ms ease, transform 180ms ease;
    z-index: 60;
  }

  .brand:hover,
  .brand:focus-visible {
    opacity: 0.86;
    transform: translateY(-1px);
  }

  .brand img {
    width: min(136px, 42vw);
    height: auto;
  }

  /* Menu Toggle Button styling */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 60;
  }

  .menu-bar {
    width: 100%;
    height: 2px;
    background-color: var(--white);
    transition: transform 220ms ease, opacity 220ms ease;
  }

  /* Hamburger transform when menu is open */
  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .nav-menu {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex: 1;
    margin-left: 2rem;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  nav a {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.94rem;
    font-weight: 800;
    text-decoration: none;
    transition: color 180ms ease;
  }

  nav a:hover,
  nav a:focus-visible {
    color: var(--white);
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    gap: 0.28rem;
    align-items: center;
    padding: 0.4rem 0;
  }

  .caret {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    transition: transform 160ms ease;
  }

  .nav-dropdown:hover .caret {
    transform: rotate(180deg);
    color: var(--white);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 2px;
    background: var(--marigold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 180ms ease;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-dropdown:focus-within .nav-link::after,
  .nav-dropdown:hover .nav-link::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 0.85rem);
    left: 0;
    z-index: 40;
    display: grid;
    width: 560px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.35rem;
    padding: 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    background: rgba(10, 92, 96, 0.97);
    box-shadow: 0 26px 70px rgba(0, 0, 0, 0.3);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.98);
    transform-origin: top center;
    transition: opacity 160ms ease, transform 160ms ease;
    backdrop-filter: blur(18px);
  }

  .dropdown-panel::before {
    content: "";
    position: absolute;
    inset: -0.9rem 0 auto;
    height: 0.9rem;
  }

  /* back button hidden on desktop */
  .submenu-back { display: none; }

  .nav-dropdown:hover .dropdown-panel,
  .nav-dropdown:focus-within .dropdown-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .dropdown-panel a {
    display: grid;
    gap: 0.16rem;
    padding: 0.85rem;
    border-radius: 18px;
    text-decoration: none;
    transition: background 160ms ease, transform 160ms ease;
  }

  .dropdown-panel a:hover,
  .dropdown-panel a:focus-visible {
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-1px);
  }

  .dropdown-panel strong {
    color: var(--white);
    font-size: 0.96rem;
  }

  .dropdown-panel small {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nav-cta {
    padding: 0.72rem 1.4rem;
    border: 1px solid var(--white);
    border-radius: 999px;
    background: transparent;
    color: var(--white);
    font-weight: 800;
    text-decoration: none;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .nav-cta:hover,
  .nav-cta:focus-visible {
    background: rgba(255,255,255,0.12);
  }

  .nav-cta-primary {
    background: var(--moss);
    border-color: var(--moss);
    color: var(--white);
  }

  .nav-cta-primary:hover,
  .nav-cta-primary:focus-visible {
    background: var(--bayou);
    border-color: var(--bayou);
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: flex;
    }

    .brand img {
      width: min(120px, 40vw);
    }

    .nav-wrap {
      min-height: 72px;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: 0;
      width: 320px;
      max-width: 100vw;
      height: 100vh;
      background: rgba(10, 92, 96, 0.99);
      backdrop-filter: blur(24px);
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 0;
      padding: 5rem 1.5rem 2rem;
      z-index: 55;
      transform: translateX(100%);
      transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
      margin-left: 0;
      overflow-y: auto;
    }

    .nav-menu.is-active {
      transform: translateX(0);
    }

    nav {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      width: 100%;
    }

    .nav-link {
      font-size: 1.1rem;
      padding: 0.75rem 0.5rem;
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .caret {
      color: rgba(255, 255, 255, 0.7);
    }

    .nav-dropdown {
      position: static;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }

    /* Disable hover/focus-within opening on mobile — JS only */
    .nav-dropdown:hover .dropdown-panel,
    .nav-dropdown:focus-within .dropdown-panel {
      opacity: 0;
      pointer-events: none;
      transform: translateY(8px) scale(0.98);
    }

    .dropdown-panel {
      position: static;
      width: 100%;
      grid-template-columns: 1fr;
      box-shadow: none;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(0,0,0,0.2);
      padding: 0.5rem;
      border-radius: 16px;
      margin-top: 0.5rem;
      display: none;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      transition: none;
    }

    /* is-open overrides everything — must come AFTER the hover/focus-within disable */
    .nav-dropdown.is-open .dropdown-panel {
      display: grid !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      transform: none !important;
    }

    .nav-dropdown.is-open .caret {
      transform: rotate(180deg);
    }

    /* Back button — only visible on mobile */
    .submenu-back {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      width: 100%;
      padding: 0.6rem 0.85rem;
      background: rgba(255,255,255,0.08);
      border: none;
      border-radius: 10px;
      color: rgba(255,255,255,0.8);
      font-size: 0.88rem;
      font-weight: 800;
      cursor: pointer;
      margin-bottom: 0.3rem;
      text-align: left;
    }

    .submenu-back:hover { background: rgba(255,255,255,0.14); }

    .nav-cta, .nav-cta-primary {
      width: 100%;
      text-align: center;
      font-size: 1.1rem;
      padding: 0.85rem 1.5rem;
    }
  }
</style>
