---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
};

const { eyebrow, title, lead, primary, secondary } = Astro.props;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy animate-in">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{lead}</p>
      {(primary || secondary) && (
        <div class="button-row">
          {primary && <a class="button" href={primary.href}>{primary.label}</a>}
          {secondary && <a class="button secondary" href={secondary.href}>{secondary.label}</a>}
        </div>
      )}
    </div>
    <aside class="hero-panel animate-in" style="animation-delay: 120ms" aria-label="i3Developers service focus">
      <div class="panel-orb" aria-hidden="true"></div>
      <span class="panel-label">Lafayette digital studio</span>
      <strong>Websites, search, and software shaped around real business momentum.</strong>
      <p>
        A refined online presence for local brands that need clarity, credibility, and a sharper path from visitor to lead.
      </p>
      <div class="signal-row" aria-label="Primary outcomes">
        <span>Design</span>
        <span>Rank</span>
        <span>Convert</span>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(2.5rem, 5vw, 4.8rem) 0 3rem;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -8rem;
    bottom: 1rem;
    width: min(50vw, 600px);
    height: min(50vw, 600px);
    border: 1px solid rgba(16, 33, 31, 0.12);
    border-radius: 42% 58% 62% 38%;
    background:
      linear-gradient(135deg, rgba(132, 176, 38, 0.22), transparent),
      radial-gradient(circle at 50% 50%, rgba(77, 125, 146, 0.18), transparent 62%);
    z-index: -1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.42fr);
    gap: clamp(1.5rem, 3.5vw, 3rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 1rem;
  }

  .hero-copy h1 {
    font-size: clamp(2.2rem, 4.4vw, 4.2rem);
    line-height: 1.02;
  }

  .hero-copy .lead {
    max-width: 720px;
  }

  .hero-panel {
    position: relative;
    display: grid;
    gap: 0.9rem;
    padding: clamp(1.1rem, 2.2vw, 1.6rem);
    border: 1px solid var(--ink);
    border-radius: 26px;
    background:
      linear-gradient(145deg, rgba(16, 33, 31, 0.98), rgba(0, 79, 98, 0.98)),
      radial-gradient(circle at 75% 12%, rgba(132, 176, 38, 0.28), transparent 16rem);
    box-shadow: 0 24px 60px rgba(0, 79, 98, 0.18);
    color: var(--white);
    isolation: isolate;
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    inset: 10px;
    border: 1px dashed rgba(255, 250, 240, 0.22);
    border-radius: 18px;
    pointer-events: none;
  }

  .hero-panel::after {
    content: "";
    position: absolute;
    inset: auto 1rem 1rem auto;
    width: 68px;
    height: 68px;
    border: 1px solid rgba(255, 250, 240, 0.14);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(132, 176, 38, 0.28), transparent 66%);
    z-index: -1;
  }

  .panel-orb {
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255, 250, 240, 0.2);
    border-radius: 18px 50% 42% 50%;
    background:
      radial-gradient(circle at 34% 30%, rgba(255, 250, 240, 0.9), transparent 0.28rem),
      linear-gradient(135deg, var(--marigold), var(--crawfish));
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
    animation: quietFloat 6s ease-in-out infinite;
  }

  .panel-label {
    color: var(--marigold);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-panel strong {
    max-width: 290px;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.1vw, 1.95rem);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .hero-panel p {
    color: rgba(255, 250, 240, 0.72);
    font-size: 0.92rem;
  }

  .signal-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .signal-row span {
    padding: 0.45rem 0.65rem;
    border: 1px solid rgba(255, 250, 240, 0.12);
    border-radius: 999px;
    background: rgba(255, 250, 240, 0.06);
    font-weight: 800;
    font-size: 0.82rem;
    text-align: center;
  }

  @keyframes quietFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(-2deg);
    }
    50% {
      transform: translate3d(0, -6px, 0) rotate(3deg);
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-panel {
      max-width: 480px;
    }
  }
</style>
