---
import { site } from "@/data/site";

type Props = {
  eyebrow: string;
  title: string;
  lead: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
};

const { eyebrow, title, lead, primary, secondary } = Astro.props;
---

<section class="hero">
  <div class="container">
    <div class="hero-copy animate-in">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{lead}</p>
      {(primary || secondary) && (
        <div class="button-row">
          {primary && <a class="button" href={primary.href}>{primary.label}</a>}
          {secondary && <a class="button secondary" href={secondary.href}>{secondary.label}</a>}
        </div>
      )}
    </div>

    <div class="proof-bar animate-in" style="animation-delay: 140ms" aria-label="Trust signals">
      <div class="proof-item">
        <strong>Since 2004</strong>
        <span>Lafayette agency</span>
      </div>
      <div class="divider" aria-hidden="true"></div>
      <div class="proof-item">
        <div class="stars" aria-label="5 star rating">★★★★★</div>
        <span>Google Reviews</span>
      </div>
      <div class="divider" aria-hidden="true"></div>
      <div class="proof-item">
        <strong>8 services</strong>
        <span>Under one roof</span>
      </div>
      <div class="divider" aria-hidden="true"></div>
      <a class="proof-item proof-cta" href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer" aria-label="See our Google reviews">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="#EA4335" d="M12 5.04c1.66 0 3.2.57 4.38 1.69l3.27-3.27C17.67 1.6 15.02 1 12 1 7.37 1 3.4 3.66 1.48 7.54l3.89 3c.96-2.88 3.66-5.5 6.63-5.5z"/>
          <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.02 3.68-8.64z"/>
          <path fill="#FBBC05" d="M5.37 14.54c-.24-.72-.37-1.5-.37-2.3a7.8 7.8 0 01.37-2.3L1.48 7.54C.54 9.43 0 11.59 0 13.88s.54 4.45 1.48 6.34l3.89-3z"/>
          <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.92l-3.77-2.92c-1.04.7-2.38 1.12-4.19 1.12-2.97 0-5.67-2.62-6.63-5.5l-3.89 3C3.4 20.34 7.37 23 12 23z"/>
        </svg>
        <span>See reviews</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 6vw, 5.5rem) 0 clamp(2rem, 4vw, 3.5rem);
  }

  /* Subtle background accent — keeps depth without competing */
  .hero::before {
    content: "";
    position: absolute;
    top: -10rem;
    right: -12rem;
    width: min(55vw, 700px);
    height: min(55vw, 700px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(132, 176, 38, 0.1) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .hero-copy {
    display: grid;
    gap: 1.25rem;
    max-width: 860px;
  }

  .hero-copy h1 {
    font-size: clamp(2.4rem, 5vw, 5.5rem);
    line-height: 1.0;
  }

  .hero-copy .lead {
    max-width: 680px;
  }

  /* Proof bar */
  .proof-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding: 1rem 1.5rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 250, 240, 0.6);
    backdrop-filter: blur(10px);
    width: fit-content;
    max-width: 100%;
  }

  .proof-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.1rem 1.25rem;
  }

  .proof-item strong {
    font-size: 1rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
  }

  .proof-item span {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(16, 33, 31, 0.52);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stars {
    font-size: 0.9rem;
    color: var(--marigold);
    line-height: 1.2;
    letter-spacing: 0.04em;
  }

  .divider {
    width: 1px;
    height: 32px;
    background: var(--line);
    flex-shrink: 0;
  }

  .proof-cta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 160ms ease;
    padding: 0.1rem 0 0.1rem 1.25rem;
  }

  .proof-cta span {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--bayou);
    text-transform: none;
    letter-spacing: 0;
  }

  .proof-cta:hover {
    opacity: 0.72;
  }

  @media (max-width: 640px) {
    .proof-bar {
      gap: 0.75rem;
      padding: 0.9rem 1rem;
    }

    .proof-item {
      padding: 0.1rem 0.75rem;
    }

    .divider {
      display: none;
    }
  }
</style>
