---
import { site } from "@/data/site";

type Props = {
  eyebrow: string;
  title: string;
  lead: string;
  primary?: { label: string; href: string };
  secondary?: { label: string; href: string };
  bgImage?: string;
};

const { eyebrow, title, lead, primary, secondary, bgImage } = Astro.props;

const slides = [
  {
    src: "/images/webdesign.png",
    alt: "Web design project for a Lafayette business",
    eyebrow: "We are passionate about",
    heading: "Lafayette Website Design & Custom Web Solutions",
    lead: "We craft fast, beautiful, conversion-focused websites for Lafayette businesses — built to rank on Google and turn visitors into real leads.",
    cta: { label: "Explore Web Design", href: "/services/lafayette-website-development-web-design/" },
  },
  {
    src: "/images/seo.jpg",
    alt: "Local SEO strategy for Lafayette search rankings",
    eyebrow: "We are passionate about",
    heading: "SEO Services That Put Lafayette Businesses at the Top",
    lead: "Our local SEO strategies are designed around how Acadiana buyers search — so your business shows up first when it matters most.",
    cta: { label: "See SEO Services", href: "/services/search-engine-marketing-seo-services-lafayette-la/" },
  },
  {
    src: "/images/Social.jpg",
    alt: "Social media marketing campaign for a Lafayette brand",
    eyebrow: "We are passionate about",
    heading: "Social Media Marketing That Builds Real Audiences",
    lead: "From content strategy to paid campaigns, we help Lafayette brands grow their following and turn engagement into business.",
    cta: { label: "Social Media Services", href: "/services/social-media-marketing-in-lafayette-la/" },
  },
  {
    src: "/images/ecommerce.jpg",
    alt: "Ecommerce storefront development for a Lafayette online store",
    eyebrow: "We are passionate about",
    heading: "Ecommerce Development Built to Sell",
    lead: "We design and develop online stores with clean product architecture, optimized checkout flow, and SEO-ready category pages.",
    cta: { label: "Ecommerce Solutions", href: "/services/ecommerce-development-lafayette-la/" },
  },
  {
    src: "/images/appDevelopment.jpg",
    alt: "Custom mobile app development for a Lafayette business",
    eyebrow: "We are passionate about",
    heading: "Custom App Development for Lafayette Businesses",
    lead: "iOS, Android, and cross-platform apps designed around your real workflows — not generic templates.",
    cta: { label: "App Development", href: "/services/lafayette-custom-app-development/" },
  },
  {
    src: "/images/Custom.jpg",
    alt: "Custom software development and workflow automation in Lafayette",
    eyebrow: "We are passionate about",
    heading: "Custom Software That Replaces Manual Workflows",
    lead: "When off-the-shelf tools do not fit, we build dashboards, portals, and internal tools that work exactly the way your team does.",
    cta: { label: "Custom Software", href: "/services/lafayette-custom-software-development/" },
  },
  {
    src: "/images/brand.png",
    alt: "Brand identity and print design for a Lafayette company",
    eyebrow: "We are passionate about",
    heading: "Branding & Print Design That Makes You Memorable",
    lead: "Logos, identity systems, and print-ready materials that keep your Lafayette business consistent from web to storefront.",
    cta: { label: "Branding & Print", href: "/services/lafayette-branding-and-print/" },
  },
  {
    src: "/images/networking.png",
    alt: "Digital marketing agency services for Lafayette businesses",
    eyebrow: "Our passion drives us",
    heading: "Full-Service Marketing Agency in Lafayette, LA",
    lead: "Strategy, campaigns, search, social, and websites — all working together as one Lafayette growth system since 2004.",
    cta: { label: "Marketing Services", href: "/services/best-marketing-agency-services-lafayette/" },
  },
];

const useCarousel = !bgImage;
---

<section class="hero" aria-label="Hero">

  {useCarousel ? (
    <>
      {/* Background image slides */}
      <div class="carousel" aria-hidden="true">
        {slides.map((slide, i) => (
          <div class={`slide${i === 0 ? " active" : ""}`} data-index={i}>
            <img src={slide.src} alt={slide.alt} loading={i === 0 ? "eager" : "lazy"} />
            <div class="overlay"></div>
          </div>
        ))}
      </div>

      {/* Per-slide text panels */}
      <div class="slide-copies">
        {slides.map((slide, i) => (
          <div class={`slide-copy${i === 0 ? " active" : ""}`} data-index={i}>
            <p class="slide-eyebrow">{slide.eyebrow}</p>
            <h1>{slide.heading}</h1>
            <p class="slide-lead">{slide.lead}</p>
            <div class="button-row">
              <a class="button" href={slide.cta.href}>{slide.cta.label}</a>
              <a class="button secondary" href="/contact/">Get in Touch</a>
            </div>
          </div>
        ))}
      </div>

      {/* Dot nav */}
      <nav class="dot-nav" aria-label="Carousel navigation">
        {slides.map((_, i) => (
          <button class={`dot${i === 0 ? " active" : ""}`} data-target={i}
            aria-label={`Slide ${i + 1}`} aria-current={i === 0 ? "true" : "false"}></button>
        ))}
      </nav>

      {/* Proof bar */}
      <div class="container">
        <div class="proof-bar animate-in" style="animation-delay:140ms" aria-label="Trust signals">
          <div class="proof-item">
            <strong>Since 2004</strong>
            <span>Lafayette agency</span>
          </div>
          <div class="divider" aria-hidden="true"></div>
          <div class="proof-item">
            <div class="stars" aria-label="5 star rating">★★★★★</div>
            <span>Google Reviews</span>
          </div>
          <div class="divider" aria-hidden="true"></div>
          <div class="proof-item">
            <strong>8 services</strong>
            <span>Under one roof</span>
          </div>
          <div class="divider" aria-hidden="true"></div>
          <a class="proof-item proof-cta" href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer" aria-label="See our Google reviews">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path fill="#EA4335" d="M12 5.04c1.66 0 3.2.57 4.38 1.69l3.27-3.27C17.67 1.6 15.02 1 12 1 7.37 1 3.4 3.66 1.48 7.54l3.89 3c.96-2.88 3.66-5.5 6.63-5.5z"/>
              <path fill="#4285F4" d="M23.49 12.27c0-.81-.07-1.59-.2-2.36H12v4.51h6.46c-.29 1.48-1.14 2.73-2.42 3.57l3.77 2.92c2.2-2.03 3.68-5.02 3.68-8.64z"/>
              <path fill="#FBBC05" d="M5.37 14.54c-.24-.72-.37-1.5-.37-2.3a7.8 7.8 0 01.37-2.3L1.48 7.54C.54 9.43 0 11.59 0 13.88s.54 4.45 1.48 6.34l3.89-3z"/>
              <path fill="#34A853" d="M12 23c3.24 0 5.97-1.07 7.96-2.92l-3.77-2.92c-1.04.7-2.38 1.12-4.19 1.12-2.97 0-5.67-2.62-6.63-5.5l-3.89 3C3.4 20.34 7.37 23 12 23z"/>
            </svg>
            <span>See reviews</span>
          </a>
        </div>
      </div>
    </>
  ) : (
    <>
      <div class="bg-static" aria-hidden="true">
        <img src={bgImage} alt="" loading="eager" fetchpriority="high" />
        <div class="overlay"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-copy animate-in">
          <p class="eyebrow">{eyebrow}</p>
          <h1>{title}</h1>
          <p class="lead">{lead}</p>
          {(primary || secondary) && (
            <div class="button-row">
              {primary   && <a class="button"           href={primary.href}>{primary.label}</a>}
              {secondary && <a class="button secondary" href={secondary.href}>{secondary.label}</a>}
            </div>
          )}
        </div>
      </div>
    </>
  )}
</section>

{useCarousel && (
<script>
  const slides    = document.querySelectorAll<HTMLElement>('.slide');
  const copies    = document.querySelectorAll<HTMLElement>('.slide-copy');
  const dots      = document.querySelectorAll<HTMLButtonElement>('.dot');

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides[current].classList.remove('active');
    copies[current].classList.remove('active');
    dots[current].classList.remove('active');
    dots[current].setAttribute('aria-current', 'false');
    current = idx;
    slides[current].classList.add('active');
    copies[current].classList.add('active');
    dots[current].classList.add('active');
    dots[current].setAttribute('aria-current', 'true');
  }

  function startTimer() { timer = setInterval(() => goTo((current + 1) % slides.length), 5000); }
  function resetTimer()  { clearInterval(timer); startTimer(); }

  dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); resetTimer(); }));

  const hero = document.querySelector('.hero') as HTMLElement;
  hero.addEventListener('mouseenter', () => clearInterval(timer));
  hero.addEventListener('mouseleave', startTimer);

  startTimer();
</script>
)}

<style>
  .hero {
    position: relative;
    min-height: clamp(520px, 88vh, 780px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  /* images */
  .carousel, .bg-static { position: absolute; inset: 0; z-index: 0; }

  .slide img, .bg-static img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center; display: block;
  }

  .overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top,  rgba(6,12,22,0.92) 0%, rgba(6,12,22,0.55) 50%, rgba(6,12,22,0.2) 100%),
      linear-gradient(to right, rgba(6,12,22,0.4) 0%, transparent 65%);
  }

  .slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1.2s ease; will-change: opacity; }
  .slide.active { opacity: 1; }

  /* per-slide text panels */
  .slide-copies {
    position: relative;
    z-index: 5;
    width: 100%;
    padding: 0 max(20px, calc((100% - 1180px) / 2));
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    padding-top: clamp(5rem, 10vw, 8rem);
  }

  .slide-copy {
    display: none;
    max-width: 780px;
    animation: slideUp 0.6s ease both;
  }
  .slide-copy.active { display: grid; gap: 1.2rem; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .slide-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  .slide-eyebrow::before {
    content: "";
    width: 28px; height: 2px;
    background: var(--moss);
    flex-shrink: 0;
  }

  .slide-copy h1 {
    color: #fff;
    font-size: clamp(2.2rem, 4.5vw, 5rem);
    line-height: 1.02;
    text-shadow: 0 2px 24px rgba(0,0,0,0.4);
    margin: 0;
  }

  .slide-lead {
    color: rgba(255,255,255,0.82);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    max-width: 620px;
    margin: 0;
  }

  .slide-copy .button {
    background: #fff; border-color: #fff; color: var(--ink);
    box-shadow: 0 12px 28px rgba(0,0,0,0.22);
  }
  .slide-copy .button:hover { background: var(--moss); border-color: var(--moss); color: #fff; }
  .slide-copy .button.secondary { background: transparent; border-color: rgba(255,255,255,0.5); color: #fff; }
  .slide-copy .button.secondary:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

  /* dot nav */
  .dot-nav {
    position: absolute;
    bottom: clamp(1.2rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2.5rem);
    z-index: 10;
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .dot {
    width: 7px; height: 7px;
    border-radius: 999px; border: none;
    background: rgba(255,255,255,0.38);
    cursor: pointer; padding: 0;
    transition: width 280ms ease, background 280ms ease;
  }
  .dot.active { width: 22px; background: #fff; }
  .dot:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }

  /* proof bar */
  .proof-bar {
    position: relative; z-index: 5;
    display: flex; align-items: center; flex-wrap: wrap;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    margin-top: 1.5rem;
    padding: 0.85rem 1.4rem;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 14px;
    background: rgba(6,12,22,0.55);
    backdrop-filter: blur(14px);
    width: fit-content; max-width: 100%;
  }

  .proof-item { display: flex; flex-direction: column; gap: 0.12rem; padding: 0.1rem 1.2rem; }
  .proof-item strong { font-size: .95rem; font-weight: 800; color: #fff; line-height: 1.2; }
  .proof-item span   { font-size: .72rem; font-weight: 700; color: rgba(255,255,255,.52); text-transform: uppercase; letter-spacing: .06em; }
  .stars { font-size: .88rem; color: #f5c842; line-height: 1.2; }
  .divider { width: 1px; height: 28px; background: rgba(255,255,255,.18); flex-shrink: 0; }
  .proof-cta { display: flex; flex-direction: row; align-items: center; gap: .5rem; text-decoration: none; padding: .1rem 0 .1rem 1.2rem; transition: opacity 160ms ease; }
  .proof-cta span { font-size: .8rem; font-weight: 800; color: rgba(255,255,255,.8); }
  .proof-cta:hover { opacity: .72; }

  /* inner page hero */
  .hero-inner { position: relative; z-index: 5; padding-bottom: clamp(2.5rem,5vw,4rem); padding-top: clamp(5rem,10vw,8rem); }
  .hero-copy { display: grid; gap: 1.25rem; max-width: 780px; }
  .hero-copy .eyebrow       { color: rgba(255,255,255,0.75); }
  .hero-copy .eyebrow::before { background: rgba(255,255,255,0.5); }
  .hero-copy h1 { color: #fff; font-size: clamp(2.4rem,5vw,5.5rem); line-height: 1.0; text-shadow: 0 2px 24px rgba(0,0,0,0.3); }
  .hero-copy .lead { color: rgba(255,255,255,0.82); max-width: 620px; }
  .hero-copy .button { background: #fff; border-color: #fff; color: var(--ink); box-shadow: 0 14px 34px rgba(0,0,0,0.25); }
  .hero-copy .button:hover { background: var(--moss); border-color: var(--moss); color: #fff; }
  .hero-copy .button.secondary { background: transparent; border-color: rgba(255,255,255,0.55); color: #fff; }
  .hero-copy .button.secondary:hover { background: rgba(255,255,255,0.12); border-color: #fff; }

  @media (max-width: 640px) {
    .proof-bar   { padding: .8rem 1rem; }
    .proof-item  { padding: .1rem .7rem; }
    .divider     { display: none; }
    .dot-nav     { right: 50%; transform: translateX(50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
    .slide-copy { animation: none; }
  }
</style>
