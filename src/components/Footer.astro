---
import { Image } from "astro:assets";
import logo from "@/assets/i3Developers-mainlogo-white.png";
import { nav, site } from "@/data/site";
import { services } from "@/data/services";
import { locations } from "@/data/locations";
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <Image class="footer-logo" src={logo} alt="i3Developers - Lafayette Web Design, SEO & Digital Marketing Agency" width={375} height={90} loading="lazy" format="webp" />
      <p class="eyebrow">Built for Lafayette</p>
      <h2>Let the website do more of the selling.</h2>
      <p class="footer-lead">
        Web design, SEO, marketing, apps, ecommerce, branding, and custom development for businesses across {site.area}.
      </p>
      <div class="footer-contact-info">
        <p class="address-block">
          <strong>Office Address:</strong><br />
          {site.streetAddress}<br />
          {site.addressLocality}, {site.addressRegion} {site.postalCode}
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/contact/">Request a consultation</a>
        <a class="button secondary" href={site.phoneHref}>Call {site.phone}</a>
      </div>
    </div>
    <div class="footer-links">
      <section>
        <h3>Navigate</h3>
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </section>
      <section>
        <h3>Services</h3>
        {services.slice(0, 6).map((service) => (
          <a href={`/services/${service.slug}/`}>{service.shortTitle}</a>
        ))}
      </section>
      <section>
        <h3>Locations We Serve</h3>
        {locations.map((loc) => (
          <a href={`/locations/${loc.slug}/`}>{loc.city}, LA</a>
        ))}
      </section>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>Copyright © 2026 i3Developers. Lafayette, LA digital agency.</p>
    <div class="footer-legal">
      <a href="/privacy/">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <a href="/terms/">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 5rem 0 2rem;
    color: var(--white);
    background:
      radial-gradient(circle at 15% 20%, rgba(231, 168, 59, 0.24), transparent 26rem),
      linear-gradient(145deg, var(--bayou), var(--ink));
  }

  .footer h2,
  .footer h3,
  .footer .eyebrow {
    color: var(--white);
  }

  .footer .eyebrow::before {
    background: var(--marigold);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 1fr);
    gap: 4rem;
  }

  .footer-logo {
    width: min(155px, 56vw);
    height: auto;
    margin-bottom: 1.4rem;
    filter: drop-shadow(0 16px 24px rgba(0, 0, 0, 0.24));
  }

  .footer-lead {
    max-width: 680px;
    margin: 1.1rem 0 1.2rem;
    color: rgba(255, 250, 240, 0.74);
    font-size: 1.2rem;
  }

  .footer-contact-info {
    margin-bottom: 1.8rem;
    color: rgba(255, 250, 240, 0.85);
  }

  .address-block {
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .address-block strong {
    color: var(--marigold);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer .button {
    color: var(--ink);
    background: var(--marigold);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .footer .button.secondary {
    color: var(--white);
    background: transparent;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .footer-links section {
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  .footer-links h3 {
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
  }

  .footer-links a {
    color: rgba(255, 250, 240, 0.78);
    font-weight: 700;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 160ms ease;
  }

  .footer-links a:hover {
    color: var(--marigold);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 250, 240, 0.18);
    color: rgba(255, 250, 240, 0.62);
    font-size: 0.9rem;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer-legal a {
    color: rgba(255, 250, 240, 0.62);
    text-decoration: none;
    font-weight: 700;
    transition: color 160ms ease;
  }

  .footer-legal a:hover {
    color: var(--marigold);
  }

  .footer-legal span {
    color: rgba(255, 250, 240, 0.3);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
