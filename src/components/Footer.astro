---
import { Image } from "astro:assets";
import logo from "@/assets/i3Developers-mainlogo-white.png";
import { nav, site } from "@/data/site";
import { services } from "@/data/services";
import { locations } from "@/data/locations";
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <Image class="footer-logo" src={logo} alt="i3Developers - Lafayette Web Design, SEO & Digital Marketing Agency" width={375} height={90} loading="lazy" format="webp" />
      <p class="eyebrow">Built for Lafayette</p>
      <h2>Let the website do more of the selling.</h2>
      <p class="footer-lead">
        Web design, SEO, marketing, apps, ecommerce, branding, and custom development for businesses across {site.area}.
      </p>
      <div class="footer-contact-info">
        <p class="address-block">
          <strong>Office Address:</strong><br />
          {site.streetAddress}<br />
          {site.addressLocality}, {site.addressRegion} {site.postalCode}
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/contact/">Request a consultation</a>
        <a class="button secondary" href={site.phoneHref}>Call {site.phone}</a>
      </div>
      <div class="social-links">
        {site.facebookUrl && (
          <a href={site.facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="i3Developers on Facebook" class="social-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.5c-1.5 0-1.96.93-1.96 1.89v2.26h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/>
            </svg>
          </a>
        )}
        {site.instagramUrl && (
          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="i3Developers on Instagram" class="social-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        )}
        <a href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer" aria-label="i3Developers on Google" class="social-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </a>
      </div>
    </div>
    <div class="footer-links">
      <section>
        <h3>Navigate</h3>
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </section>
      <section>
        <h3>Services</h3>
        {services.slice(0, 6).map((service) => (
          <a href={`/services/${service.slug}/`}>{service.shortTitle}</a>
        ))}
      </section>
      <section>
        <h3>Locations We Serve</h3>
        {locations.map((loc) => (
          <a href={`/locations/${loc.slug}/`}>{loc.city}, LA</a>
        ))}
      </section>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>Copyright © {new Date().getFullYear()} i3Developers. Lafayette, LA digital agency.</p>
    <div class="footer-legal">
      <a href="/privacy/">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <a href="/terms/">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 5rem 0 2rem;
    color: var(--white);
    background:
      radial-gradient(circle at 15% 20%, rgba(231, 168, 59, 0.24), transparent 26rem),
      linear-gradient(145deg, var(--bayou), var(--ink));
  }

  .footer h2,
  .footer h3,
  .footer .eyebrow {
    color: var(--white);
  }

  .footer .eyebrow::before {
    background: var(--marigold);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 1fr);
    gap: 4rem;
  }

  .footer-logo {
    width: min(155px, 56vw);
    height: auto;
    margin-bottom: 1.4rem;
    filter: drop-shadow(0 16px 24px rgba(0, 0, 0, 0.24));
  }

  .footer-lead {
    max-width: 680px;
    margin: 1.1rem 0 1.2rem;
    color: rgba(255, 250, 240, 0.74);
    font-size: 1.2rem;
  }

  .footer-contact-info {
    margin-bottom: 1.8rem;
    color: rgba(255, 250, 240, 0.85);
  }

  .address-block {
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .address-block strong {
    color: var(--marigold);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer .button {
    color: var(--ink);
    background: var(--marigold);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .footer .button.secondary {
    color: var(--white);
    background: transparent;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .footer-links section {
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  .footer-links h3 {
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
  }

  .footer-links a {
    color: rgba(255, 250, 240, 0.78);
    font-weight: 700;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 160ms ease;
  }

  .footer-links a:hover {
    color: var(--marigold);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 250, 240, 0.18);
    color: rgba(255, 250, 240, 0.62);
    font-size: 0.9rem;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer-legal a {
    color: rgba(255, 250, 240, 0.62);
    text-decoration: none;
    font-weight: 700;
    transition: color 160ms ease;
  }

  .footer-legal a:hover {
    color: var(--marigold);
  }

  .footer-legal span {
    color: rgba(255, 250, 240, 0.3);
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 250, 240, 0.2);
    border-radius: 10px;
    color: rgba(255, 250, 240, 0.7);
    transition: color 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .social-icon:hover {
    color: var(--white);
    border-color: var(--marigold);
    background: rgba(132, 176, 38, 0.15);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
