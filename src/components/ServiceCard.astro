---
import type { Service } from "@/data/services";

type Props = {
  service: Service;
  index?: number;
};

const { service, index = 0 } = Astro.props;
---

<article class="service-card card animate-in" style={`animation-delay: ${index * 55}ms`}>
  <span>{String(index + 1).padStart(2, "0")}</span>
  <h3>{service.shortTitle}</h3>
  <p>{service.description}</p>
  <a href={`/services/${service.slug}/`} aria-label={`Learn more about ${service.title}`}>Explore service</a>
</article>

<style>
  .service-card {
    position: relative;
    display: grid;
    min-height: 300px;
    gap: 1rem;
    align-content: start;
    padding: 1.35rem;
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .service-card::after {
    content: "";
    position: absolute;
    right: -42px;
    bottom: -42px;
    width: 120px;
    height: 120px;
    border: 1px solid rgba(16, 33, 31, 0.12);
    border-radius: 50%;
    background: rgba(231, 168, 59, 0.22);
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 58px rgba(16, 33, 31, 0.13);
  }

  .service-card span {
    color: var(--crawfish);
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
  }

  .service-card p {
    color: rgba(16, 33, 31, 0.74);
  }

  .service-card a {
    width: fit-content;
    margin-top: auto;
    color: var(--cypress);
    font-weight: 900;
    text-decoration-color: var(--marigold);
    text-decoration-thickness: 3px;
    text-underline-offset: 5px;
  }
</style>
