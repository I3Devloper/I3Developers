---
import { site } from "@/data/site";
---

<section class="section cta-section">
  <div class="container cta-card">
    <p class="eyebrow">Ready when you are</p>
    <h2>Build the Lafayette site your competitors wish you would not launch.</h2>
    <p class="lead">
      Start with a sharper site, clearer service pages, stronger proof, and a search strategy built around how Lafayette customers actually choose.
    </p>
    <div class="button-row">
      <a class="button" href="/contact/">Plan my website</a>
      <a class="button secondary" href={site.phoneHref}>Call {site.phone}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: 2rem;
  }

  .cta-card {
    position: relative;
    display: grid;
    gap: 1.2rem;
    padding: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    border: 1px solid var(--ink);
    border-radius: 36px;
    background:
      radial-gradient(circle at 88% 20%, rgba(217, 87, 43, 0.18), transparent 22rem),
      linear-gradient(135deg, var(--white), var(--paper-deep));
    box-shadow: 0 28px 80px rgba(16, 33, 31, 0.16);
  }

  .cta-card h2 {
    max-width: 920px;
  }

  .cta-card .lead {
    max-width: 760px;
  }
</style>
