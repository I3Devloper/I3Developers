---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Message Sent Successfully | i3Developers"
  description="Thank you for contacting i3Developers. We have received your submission and will get back to you shortly."
  canonical="/success/"
>
  <section class="section success-hero">
    <div class="container centered animate-in">
      <div class="success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      
      <h1>Message received!</h1>
      <p class="lead">
        Thank you for reaching out. We have received your inquiry and a member of our team will contact you within 24 business hours.
      </p>

      <div class="office-details card">
        <h3>Need immediate help?</h3>
        <p>Give us a call directly to talk with our team right away:</p>
        <a class="phone-link" href={site.phoneHref}>{site.phone}</a>
      </div>
      
      <div class="button-row justify-center">
        <a class="button" href="/">Return home</a>
        <a class="button secondary" href="/about-us-best-website-design-website-development-seo-marketing-agency-in-lafayette-la/">Learn more about us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .success-hero {
    padding: clamp(5rem, 9vw, 9rem) 0 clamp(4rem, 8vw, 6rem);
    background:
      radial-gradient(circle at 50% 30%, rgba(132, 176, 38, 0.12), transparent 30rem),
      radial-gradient(circle at 90% 80%, rgba(77, 125, 146, 0.08), transparent 24rem);
  }

  .centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 620px;
    margin-inline: auto;
  }

  .success-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(132, 176, 38, 0.15);
    color: var(--marigold);
    margin-bottom: 2rem;
    box-shadow: 0 16px 36px rgba(132, 176, 38, 0.15);
  }

  .success-icon svg {
    width: 36px;
    height: 36px;
  }

  .success-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .success-hero .lead {
    color: rgba(16, 33, 31, 0.72);
    margin-bottom: 2.2rem;
  }

  .office-details {
    width: 100%;
    padding: 2.2rem;
    margin-bottom: 2.5rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 24px;
    box-shadow: var(--shadow);
    display: grid;
    gap: 0.6rem;
  }

  .office-details h3 {
    font-size: 1.4rem;
    color: var(--ink);
  }

  .office-details p {
    color: rgba(16, 33, 31, 0.68);
    font-size: 0.98rem;
  }

  .phone-link {
    display: inline-block;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--marigold);
    text-decoration: none;
    transition: color 180ms ease, transform 180ms ease;
  }

  .phone-link:hover {
    color: var(--ink);
    transform: translateY(-1px);
  }

  .justify-center {
    justify-content: center;
    width: 100%;
  }
</style>
