---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
import { breadcrumbSchema } from "@/lib/seo";
---

<BaseLayout
  title="Terms of Service | i3Developers - Lafayette, LA"
  description="Terms and conditions for using i3Developers website and services. Read our terms of service for web design, SEO, and digital marketing in Lafayette, LA."
  canonical="/terms/"
  schema={[breadcrumbSchema([{ name: "Home", url: "/" }, { name: "Terms of Service", url: "/terms/" }])]}
>
  <section class="section policy-hero">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Service</h1>
      <p class="lead">Last updated: May 2026</p>
    </div>
  </section>

  <section class="section">
    <div class="container policy-body">
      <article class="card policy-card">
        <h2>1. Agreement to Terms</h2>
        <div class="rich-text">
          <p>By accessing or using the i3Developers website (i3developers.com), you agree to be bound by these Terms of Service. If you do not agree with any part of these terms, you may not use our website or services.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>2. Services</h2>
        <div class="rich-text">
          <p>i3Developers provides web design, web development, search engine optimization (SEO), digital marketing, branding, ecommerce development, app development, and custom software development services for businesses in Lafayette, Louisiana, and surrounding Acadiana communities.</p>
          <p>All service engagements are subject to separate project agreements that outline scope, deliverables, timelines, and payment terms.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>3. Intellectual Property</h2>
        <div class="rich-text">
          <p>All content on this website, including but not limited to text, graphics, logos, images, and software, is the property of i3Developers or its content suppliers and is protected by applicable copyright and trademark laws.</p>
          <ul>
            <li>You may not reproduce, distribute, or create derivative works from our content without prior written permission.</li>
            <li>Client project deliverables are subject to the terms specified in individual project contracts.</li>
          </ul>
        </div>
      </article>

      <article class="card policy-card">
        <h2>4. Website Use</h2>
        <div class="rich-text">
          <p>When using our website, you agree not to:</p>
          <ul>
            <li>Use the website for any unlawful purpose or in violation of any applicable laws</li>
            <li>Attempt to gain unauthorized access to any part of the website or its systems</li>
            <li>Interfere with the proper functioning of the website</li>
            <li>Submit false or misleading information through any forms</li>
            <li>Scrape, crawl, or use automated tools to extract content without permission</li>
          </ul>
        </div>
      </article>

      <article class="card policy-card">
        <h2>5. Disclaimer of Warranties</h2>
        <div class="rich-text">
          <p>This website and its content are provided "as is" and "as available" without warranties of any kind, either express or implied. i3Developers does not warrant that:</p>
          <ul>
            <li>The website will be uninterrupted, secure, or error-free</li>
            <li>Results obtained from using the website will be accurate or reliable</li>
            <li>Any defects in the website will be corrected</li>
          </ul>
        </div>
      </article>

      <article class="card policy-card">
        <h2>6. Limitation of Liability</h2>
        <div class="rich-text">
          <p>To the fullest extent permitted by law, i3Developers shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of the website or services. Our total liability shall not exceed the amount paid by you for the specific service giving rise to the claim.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>7. Third-Party Links</h2>
        <div class="rich-text">
          <p>Our website may contain links to third-party websites. These links are provided for convenience only, and i3Developers does not endorse, control, or assume responsibility for the content or practices of any third-party sites.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>8. Governing Law</h2>
        <div class="rich-text">
          <p>These Terms of Service shall be governed by and construed in accordance with the laws of the State of Louisiana, without regard to conflict of law principles. Any disputes arising under these terms shall be resolved in the courts of Lafayette Parish, Louisiana.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>9. Changes to Terms</h2>
        <div class="rich-text">
          <p>We reserve the right to modify these Terms of Service at any time. Changes will be posted on this page with an updated revision date. Continued use of the website after changes are posted constitutes acceptance of the revised terms.</p>
        </div>
      </article>

      <article class="card policy-card">
        <h2>10. Contact</h2>
        <div class="rich-text">
          <p>For questions about these Terms of Service, please contact us:</p>
          <p>
            <strong>i3Developers</strong><br />
            {site.streetAddress}<br />
            {site.addressLocality}, {site.addressRegion} {site.postalCode}<br />
            Phone: <a href={site.phoneHref}>{site.phone}</a><br />
            Email: <a href="mailto:info@i3developers.com">info@i3developers.com</a>
          </p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .policy-hero {
    padding: clamp(3rem, 6vw, 5rem) 0 2rem;
    background:
      radial-gradient(circle at 20% 30%, rgba(132, 176, 38, 0.1), transparent 28rem);
  }

  .policy-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    margin-bottom: 0.6rem;
  }

  .policy-hero .lead {
    color: rgba(16, 33, 31, 0.6);
    font-size: 0.95rem;
  }

  .policy-body {
    display: grid;
    gap: 1.2rem;
    max-width: 820px;
  }

  .policy-card {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    display: grid;
    gap: 1rem;
  }

  .policy-card h2 {
    font-size: clamp(1.3rem, 2.4vw, 1.8rem);
    line-height: 1.15;
  }

  .policy-card ul {
    display: grid;
    gap: 0.5rem;
    padding-left: 1.2rem;
    margin: 0;
  }

  .policy-card li {
    color: rgba(16, 33, 31, 0.76);
    line-height: 1.65;
  }

  .policy-card a {
    color: var(--marigold);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .policy-card a:hover {
    color: var(--ink);
  }
</style>
