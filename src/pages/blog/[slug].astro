---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTA from "@/components/CTA.astro";
import { getCollection, render } from "astro:content";
import { breadcrumbSchema, articleSchema } from "@/lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post }
  }));
}

const { post } = Astro.props;
const slug = post.id.replace(/\.md$/, "");
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.metaTitle}
  description={post.data.description}
  canonical={`/blog/${slug}/`}
  schema={[
    breadcrumbSchema([
      { name: "Home", url: "/" },
      { name: "Blog", url: "/blog/" },
      { name: post.data.title, url: `/blog/${slug}/` }
    ]),
    articleSchema(
      post.data.title,
      post.data.description,
      `https://i3developers.com/blog/${slug}/`,
      post.data.publishedDate.toISOString().split("T")[0],
      post.data.modifiedDate.toISOString().split("T")[0],
      post.data.author,
      "https://i3developers.com/about-us-best-website-design-development-seo-marketingagency-socialmediamarketing-in-lafayette-la/"
    )
  ]}
  publishedDate={post.data.publishedDate.toISOString().split("T")[0]}
  modifiedDate={post.data.modifiedDate.toISOString().split("T")[0]}
>
  <article class="article-page">
    <div class="container article-container">
      <header class="article-header">
        <a href="/blog/" class="article-back">&larr; Back to Blog</a>
        <span class="article-tag">{post.data.tag}</span>
        <h1>{post.data.title}</h1>
        <p class="article-excerpt">{post.data.excerpt}</p>
        <div class="article-meta">
          <span>By {post.data.author}</span>
          <span>{post.data.publishedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
        </div>
      </header>

      <div class="article-body">
        <Content />
      </div>

      <div class="article-footer">
        <div class="article-author-card">
          <div>
            <p class="author-name">{post.data.author}</p>
            <p class="author-role">{post.data.authorRole} at i3Developers</p>
          </div>
          <a href="/contact/" class="button">Work with us</a>
        </div>
      </div>
    </div>
  </article>

  <CTA />
</BaseLayout>

<style>
  .article-page {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .article-container {
    max-width: 780px;
  }

  .article-back {
    display: inline-block;
    color: var(--cypress);
    font-weight: 700;
    text-decoration: none;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .article-back:hover {
    color: var(--marigold);
  }

  .article-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cypress);
    background: rgba(49, 95, 83, 0.08);
    padding: 0.3rem 0.7rem;
    border-radius: 99px;
    margin-bottom: 1.2rem;
  }

  .article-header h1 {
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    margin-bottom: 1rem;
  }

  .article-excerpt {
    font-size: 1.2rem;
    color: rgba(16, 33, 31, 0.74);
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: rgba(16, 33, 31, 0.55);
    font-weight: 600;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }

  .article-body :global(h2) {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-body :global(h3) {
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    margin-top: 2rem;
    margin-bottom: 0.8rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.2rem;
    line-height: 1.7;
    color: rgba(16, 33, 31, 0.82);
    font-size: 1.05rem;
  }

  .article-body :global(ul) {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.6rem;
    line-height: 1.6;
    color: rgba(16, 33, 31, 0.82);
    font-size: 1.05rem;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }

  .article-author-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    background: rgba(49, 95, 83, 0.05);
    border-radius: 20px;
  }

  .author-name {
    font-weight: 800;
    font-size: 1.1rem;
    margin: 0;
  }

  .author-role {
    color: rgba(16, 33, 31, 0.6);
    font-size: 0.9rem;
    margin: 0.2rem 0 0;
  }

  @media (max-width: 600px) {
    .article-author-card {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
