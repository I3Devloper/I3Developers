---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import ProofSection from "@/components/ProofSection.astro";
import Testimonials from "@/components/Testimonials.astro";
import CTA from "@/components/CTA.astro";
import { services } from "@/data/services";
import { site } from "@/data/site";
import { breadcrumbSchema, faqSchema } from "@/lib/seo";

const title = "Lafayette Website Design & SEO Services | i3Developers";
const description =
  "Top Lafayette website design, development, and SEO agency. i3Developers constructs custom digital solutions that rank on Google, convert leads, and grow local businesses.";

const homeFaqs = [
  { question: "How much does a website design cost in Lafayette, LA?", answer: "Website design costs in Lafayette vary based on the number of pages, features, and complexity. Most local business websites range from a few thousand dollars for a clean brochure site to more for custom builds with ecommerce or app integrations. We provide a clear estimate after a brief consultation — no hidden fees." },
  { question: "How long does SEO take to work for a Lafayette business?", answer: "Most Lafayette businesses see measurable movement in local rankings within 60 to 90 days of consistent SEO work. Competitive terms take longer — typically 6 to 12 months for sustained top-3 positions. Technical fixes and Google Business Profile improvements often produce the fastest early results." },
  { question: "Do you work with small businesses in Acadiana?", answer: "Yes. Most of our clients are small and mid-sized businesses across Lafayette, Broussard, Youngsville, Carencro, Scott, Breaux Bridge, and New Iberia. We are familiar with the local market and build websites and search strategies around how Acadiana buyers actually search." },
  { question: "Can you redesign an existing website without losing SEO rankings?", answer: "Yes. We audit your existing URLs, traffic, and rankings before touching anything. Existing pages are preserved where possible, and any changed URLs receive permanent redirects to their new equivalents so your search visibility carries over." },
  { question: "What makes i3Developers different from other Lafayette marketing agencies?", answer: "We have been building websites and managing digital marketing for Lafayette businesses since 2004. We do not outsource work overseas, we write real content, and we measure success by leads and rankings — not vanity metrics like impressions or follower counts." },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  schema={[
    breadcrumbSchema([{ name: "Home", url: "/" }]),
    faqSchema(homeFaqs)
  ]}
>
  <Hero />

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Built with intention</p>
        <h2>Lafayette Web Design Built for Local Search and Real Leads.</h2>
      </div>
      <div class="rich-text">
        <p>
          The best local business websites feel effortless to use but are carefully planned underneath: clear service paths, useful content, local proof, fast performance, and calls to action that feel natural to a Lafayette buyer.
        </p>
        <p>
          We design every page around what a real Acadiana customer needs to know before they call, request pricing, or compare options — so your website works as hard as you do.
        </p>
      </div>
    </div>
  </section>

  <section class="section services-band">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">Core services</p>
          <h2>One Lafayette digital growth system, eight useful parts.</h2>
        </div>
        <p class="lead">
          From web design and SEO to app development, ecommerce, and branding — every service is built around what Lafayette businesses need to rank, convert, and grow.
        </p>
      </div>
      <div class="grid three">
        {services.map((service, index) => <ServiceCard service={service} index={index} />)}
      </div>
    </div>
  </section>

  <ProofSection />

  <Testimonials />

  <section class="section">
    <div class="container local-grid">
      <article class="local-main card">
        <p class="eyebrow">Local SEO stack</p>
        <h2>Designed for Lafayette and Acadiana Search Behavior.</h2>
        <p class="lead">
          Ranking locally in Lafayette is not one trick. It is page relevance, Google Business Profile alignment, reviews, citations, content quality, internal links, performance, and proof — all agreeing with each other.
        </p>
      </article>
      {[
        { title: "High-intent service pages", text: "Clear service pages targeting searches like 'web designer Lafayette LA' and 'SEO agency near me'." },
        { title: "FAQ and proof content", text: "Helpful FAQs, case study blocks, and local business context that answers what buyers ask before they call." },
        { title: "Clean site architecture", text: "Search-friendly URL structure, internal linking, and indexing paths that Google can crawl easily." },
        { title: "Review and citation strategy", text: "Case studies, Google review links, and testimonial sections that build trust with real Lafayette clients." },
        { title: "Location and industry pages", text: "Service-area pages for Broussard, Youngsville, Carencro, Scott, and across Acadiana — no keyword cannibalization." },
        { title: "Analytics and Search Console", text: "Launch checklist covering Google Search Console, GA4 setup, and post-launch ranking monitoring." },
      ].map((item) => (
        <div class="local-item">
          <strong>{item.title}</strong>
          <span>{item.text}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">Common questions</p>
          <h2>What Lafayette businesses ask before they hire a web agency.</h2>
        </div>
      </div>
      <div class="faq-grid">
        {homeFaqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>
              <span>{faq.question}</span>
              <span class="plus" aria-hidden="true"></span>
            </summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section map-section">
    <div class="container map-wrap">
      <div class="map-info card">
        <p class="eyebrow">Find us</p>
        <h2>Visit i3Developers in Lafayette.</h2>
        <p>{site.streetAddress}<br />{site.addressLocality}, {site.addressRegion} {site.postalCode}</p>
        <p><a href={site.phoneHref}>{site.phone}</a></p>
        <a class="button" href={site.googleMapsUrl} target="_blank" rel="noopener noreferrer">Get directions</a>
      </div>
      <div class="map-embed">
        <iframe
          title="i3Developers location on Google Maps"
          src={`https://maps.google.com/maps?q=${site.latitude},${site.longitude}&z=15&output=embed`}
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(300px, 0.85fr);
    gap: 2rem;
    align-items: start;
  }

  .services-band {
    background:
      linear-gradient(180deg, rgba(240, 247, 248, 0.6), rgba(13, 115, 119, 0.07)),
      linear-gradient(90deg, transparent, rgba(26, 107, 138, 0.06));
  }

  .local-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(2, minmax(0, 0.65fr));
    gap: 1rem;
  }

  .local-main {
    grid-row: span 3;
    display: grid;
    gap: 1.2rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: var(--ink);
  }

  .local-main h2,
  .local-main .eyebrow { color: var(--white); }
  .local-main .lead    { color: rgba(255, 255, 255, 0.72); }

  .local-item {
    display: grid;
    gap: 0.4rem;
    min-height: 150px;
    padding: 1.2rem;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.72);
    align-content: start;
  }

  .local-item strong { color: var(--cypress); font-size: 1rem; font-weight: 900; }
  .local-item span   { color: rgba(15, 32, 39, 0.65); font-size: 0.88rem; line-height: 1.5; }

  /* FAQ */
  .faq-section { background: linear-gradient(180deg, transparent, rgba(13,115,119,0.05)); }

  .faq-grid { display: grid; gap: 0.6rem; max-width: 860px; }

  .faq-item {
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--white);
    overflow: hidden;
    transition: border-color 180ms ease;
  }

  .faq-item[open] { border-color: var(--moss); }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    font-weight: 800;
    font-size: 1rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item[open] summary { color: var(--bayou); }

  .plus {
    flex-shrink: 0;
    position: relative;
    width: 20px; height: 20px;
    border: 1px solid var(--line);
    border-radius: 50%;
  }

  .plus::before, .plus::after {
    content: "";
    position: absolute;
    background: rgba(15,32,39,0.45);
    transition: transform 160ms ease;
  }

  .plus::before { top:50%; left:4px; right:4px; height:2px; transform:translateY(-50%); }
  .plus::after  { top:4px; bottom:4px; left:50%; width:2px; transform:translateX(-50%); }

  .faq-item[open] .plus { border-color: var(--moss); }
  .faq-item[open] .plus::after  { transform: translateX(-50%) rotate(90deg); background: var(--moss); }
  .faq-item[open] .plus::before { background: var(--moss); }

  .faq-item p {
    padding: 0 1.3rem 1.1rem;
    color: rgba(15,32,39,0.68);
    font-size: 0.94rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Map */
  .map-wrap {
    display: grid;
    grid-template-columns: minmax(280px, 0.45fr) minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .map-info {
    display: grid;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    align-content: start;
  }

  .map-info h2 { font-size: clamp(1.6rem, 2.5vw, 2.4rem); }
  .map-info p  { color: rgba(15,32,39,0.68); font-size: 0.96rem; line-height: 1.6; }
  .map-info a[href^="tel"] { color: var(--moss); font-weight: 800; text-decoration: none; }

  .map-embed {
    min-height: 400px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
  }

  .map-embed iframe { display: block; }

  @media (max-width: 900px) {
    .split, .local-grid, .map-wrap { grid-template-columns: 1fr; }
    .map-embed { min-height: 300px; }
  }
</style>
